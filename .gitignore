# Secrets — env files are per-environment and never committed.
# .env.example is the committed template. .env is kept ignored as a
# convenience for older clones that still have one.
.env
.env.local
.env.staging
.env.production

# Python
__pycache__/
*.pyc
*.pyo
.venv/
venv/
*.egg-info/
.pytest_cache/

# OS
.DS_Store
Thumbs.db

# Node / frontend tooling
node_modules/

# IDEs
.idea/
.vscode/

# Raw / processed geodata (don't commit large datasets)
data/
ingest/data/*.gpkg
ingest/data/*.zip
