# Postgres / PostGIS (used by the postgis service to initialise the DB)
POSTGRES_DB=luxbus
POSTGRES_USER=luxbus
POSTGRES_PASSWORD=changeme
POSTGRES_HOST=postgis
POSTGRES_PORT=5432

# Database connection string (used by the api).
# In production (Fly.io) this is set via: flyctl secrets set DATABASE_URL=...
# For local docker-compose, change to: postgresql://luxbus:changeme@postgis:5432/luxbus
DATABASE_URL=postgresql://user:password@localhost:5432/lux_catchment

# Environment marker (development | staging | production)
ENVIRONMENT=development

# Projected CRS used for all spatial operations (metres, not degrees)
PROJECTED_CRS=EPSG:3035
