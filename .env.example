# Template for environment files. The repo uses three real env files,
# all gitignored:
#
#   .env.local       -> local Docker (default; ENVIRONMENT unset or
#                       "development")
#   .env.staging     -> Supabase staging project
#                       (ENVIRONMENT=staging)
#   .env.production  -> Supabase production project
#                       (ENVIRONMENT=production)
#
# Workflow:
#   cp .env.example .env.local
#   (the localhost block below is already correct for local dev)
#
# Then, when you actually want to touch a remote DB:
#   cp .env.example .env.staging       # paste staging Supabase URL
#   cp .env.example .env.production    # paste production Supabase URL
#
# Run with no flags = local Docker. Run with `ENVIRONMENT=staging` or
# `ENVIRONMENT=production` prefixed to a script to pick the matching
# file. You can never accidentally overwrite production data by just
# running a script.

# ---- Local development (copy into .env.local) ----
ENVIRONMENT=development
DATABASE_URL=postgresql://luxbus:changeme@localhost:5432/luxbus
PROJECTED_CRS=EPSG:3035

# Used by docker-compose to bootstrap the postgis container. Required
# in .env.local; not used by .env.staging / .env.production.
POSTGRES_DB=luxbus
POSTGRES_USER=luxbus
POSTGRES_PASSWORD=changeme
POSTGRES_HOST=postgis
POSTGRES_PORT=5432

# ---- Staging (copy into .env.staging, uncomment, fill in) ----
# ENVIRONMENT=staging
# DATABASE_URL=postgresql://postgres:URL_ENCODED_PASSWORD@db.<staging-project>.supabase.co:5432/postgres?sslmode=require
# PROJECTED_CRS=EPSG:3035

# ---- Production (copy into .env.production, uncomment, fill in) ----
# ENVIRONMENT=production
# DATABASE_URL=postgresql://postgres:URL_ENCODED_PASSWORD@db.<prod-project>.supabase.co:5432/postgres?sslmode=require
# PROJECTED_CRS=EPSG:3035
