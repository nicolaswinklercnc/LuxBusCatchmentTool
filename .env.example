# Template for environment files. The repo uses two real env files,
# both gitignored:
#
#   .env.local       -> local Docker (default; loaded when ENVIRONMENT
#                       is unset or anything other than "production")
#   .env.production  -> Supabase (loaded when ENVIRONMENT=production)
#
# Workflow:
#   cp .env.example .env.local
#   (the localhost block below is already correct for local dev)
#
# Then, when you actually want to touch production:
#   cp .env.example .env.production
#   uncomment the production block, paste the Supabase URL, set
#   ENVIRONMENT=production.
#
# Run with no flags = local Docker. Run with ENVIRONMENT=production
# prefixed (or set in shell) = Supabase. You can never accidentally
# overwrite production data by just running a script.

# ---- Local development (copy into .env.local) ----
ENVIRONMENT=development
DATABASE_URL=postgresql://luxbus:changeme@localhost:5432/luxbus
PROJECTED_CRS=EPSG:3035

# Used by docker-compose to bootstrap the postgis container. Required
# in .env.local; not used by .env.production.
POSTGRES_DB=luxbus
POSTGRES_USER=luxbus
POSTGRES_PASSWORD=changeme
POSTGRES_HOST=postgis
POSTGRES_PORT=5432

# ---- Production (copy into .env.production, uncomment, fill in) ----
# ENVIRONMENT=production
# DATABASE_URL=postgresql://postgres:URL_ENCODED_PASSWORD@db.<project>.supabase.co:5432/postgres?sslmode=require
# PROJECTED_CRS=EPSG:3035
